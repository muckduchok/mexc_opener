# ── Global tunables (accounts + hedge groups live in config.json) ──────────────

# Path to the accounts/groups config file (JSON). Default: config.json
CONFIG_FILE=config.json

# ── Market-open schedule ───────────────────────────────────────────────────────
# Bot computes the next open strictly in this timezone, regardless of the
# server's own clock/UTC offset. Use an IANA name. Default = Polish time.
MARKET_OPEN_TZ=Europe/Warsaw
# Day of week to open on (1=Mon ... 7=Sun). "Midnight Sunday->Monday" = 1 (Monday 00:00).
MARKET_OPEN_WEEKDAY=1
MARKET_OPEN_HOUR=0
MARKET_OPEN_MINUTE=0
# Open this many milliseconds BEFORE the scheduled time (e.g. 5000 = 5s early).
# Default behaviour: open 5s before Sunday->Monday midnight, Polish time.
OPEN_LEAD_MS=5000
# Repeat every week (true) or fire only for the next occurrence then stop (false).
MARKET_OPEN_REPEAT=true
# If true, ignore the schedule and open all groups immediately on startup (TESTING).
OPEN_IMMEDIATELY=false
# TEST: open ONCE this long after startup instead of waiting for the weekly schedule.
# Accepts a duration like 30m, 1h, 90s, 1h30m, 2d (bare number = minutes). Empty = off.
# Overrides the weekly schedule (but OPEN_IMMEDIATELY still wins if set).
TEST_OPEN_AFTER=

# ── Strategy defaults (can be overridden per group in config.json) ─────────────
# How percentages are measured:
#   roe   = leveraged ROI, i.e. exactly what MEXC shows in its PnL% column (default).
#   price = raw price movement from entry (no leverage).
# NOTE: with roe, divide your "price target" intuition by leverage. e.g. on 10x,
# 0.4% roe = only 0.04% price move (very tight, near spread). Tune accordingly.
DEFAULT_PCT_BASIS=roe
# Leg that first reaches +PROFIT_TRIGGER_PCT gets a stop-loss locking +STOP_LOCK_PCT.
PROFIT_TRIGGER_PCT=0.4
STOP_LOCK_PCT=0.2
# After the first leg's stop fills, the remaining (opposite) leg: once it reaches
# +TP2_TRIGGER_PCT it gets a profit-locking exchange STOP-LOSS that locks +TP2_PCT
# (so we control the exit on a reversal). TP2_PCT must be < TP2_TRIGGER_PCT.
TP2_TRIGGER_PCT=0.4
TP2_PCT=0.2

# Price source used to evaluate PnL ("last" or "fair").
PRICE_SOURCE=last

# ── Sizing (per group, defaults here) ──────────────────────────────────────────
# size = USDT margin (collateral) committed per leg; notional = margin * leverage.
DEFAULT_MARGIN_USDT=50
DEFAULT_LEVERAGE=20
# Margin mode for opening: 1 = isolated, 2 = cross.
DEFAULT_OPEN_TYPE=1
# Position mode sent on order/submit: 1 = hedge (dual-side), 2 = one-way. This MUST
# match the account's actual setting on MEXC, otherwise orders are rejected (code 9).
DEFAULT_POSITION_MODE=1

# ── Hedge layout (per group; override with "mode" in config.json) ──────────────
#   dual   = LONG on one account, SHORT on another (two accounts). Default.
#   single = BOTH legs on ONE account (the account MUST be in Hedge mode on MEXC,
#            positionMode is forced to 1). Everything is monitored/managed on that
#            one account. Use this when running one config per server/account.
DEFAULT_HEDGE_MODE=dual

# ── Order type for opening ─────────────────────────────────────────────────────
# "limit" = marketable limit from the order book (recommended), "market" = market order.
DEFAULT_ORDER_TYPE=limit
# Depth level used for the marketable limit: LONG buys at the Nth ASK, SHORT sells at
# the Nth BID. A few levels of buffer guarantees an immediate fill with capped slippage.
DEFAULT_LIMIT_LEVEL=3

# ── Endpoints (rarely changed) ─────────────────────────────────────────────────
MEXC_PRIVATE_BASE=https://futures.mexc.com/api/v1
MEXC_CONTRACT_BASE=https://contract.mexc.com/api/v1
MEXC_WS_URL=wss://contract.mexc.com/edge

# ── MongoDB / Listings source ──────────────────────────────────────────────────
# Connection string to the SAME MongoDB the main app uses (Prisma DATABASE_URL).
# Leave empty to disable the Listings watcher entirely.
DATABASE_URL=
# Optional DB name override (otherwise taken from the connection string).
MONGO_DB_NAME=
# How often (ms) to pull Listings. Default 300000 = 5 minutes.
LISTINGS_POLL_MS=300000
# This server's number. Matched against customFields.server_number in each Listing
# (customFields is a JSON string, e.g. {"leverage":500,"open_type":1,"server_number":1}).
# Leave empty to process every matching listing (no server filter).
SERVER_NUMBER=1
# Listing.event -> hedge mode. silver_onemode = single-account hedge (one account holds
# both legs); silver_multimode = dual hedge (2 listings per server_number: side long + short).
LISTINGS_EVENT_SINGLE=silver_onemode
LISTINGS_EVENT_MULTI=silver_multimode
# Optional: restrict to one owner (Listings.userId / Account.userId, an ObjectId).
LISTINGS_USER_ID=
# Only resolve accounts whose exchange matches (case-insensitive). Empty = any.
LISTINGS_EXCHANGE=mexc
# Collection names (Prisma models have no @@map, so these match the model names).
MONGO_LISTINGS_COLLECTION=Listings
MONGO_ACCOUNTS_COLLECTION=Account

# ── Runtime ────────────────────────────────────────────────────────────────────
# How often (ms) to poll positions to detect SL/TP fills.
POSITION_POLL_MS=3000
# How often (ms) to log live per-account PnL while a hedge is open.
PNL_LOG_MS=2000
# HTTP timeout (ms).
HTTP_TIMEOUT_MS=15000
STATE_FILE=data/state.json
LOG_LEVEL=info
